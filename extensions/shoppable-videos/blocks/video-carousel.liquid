{%- if block.settings.title != blank -%}
  <h2 class="nq-section-title">{{ block.settings.title }}</h2>
{%- endif -%}

<div
  class="nq-shoppable-carousel"
  id="nq-carousel-{{ block.id }}"
  data-shop="{{ shop.permanent_domain }}"
  data-block-id="{{ block.id }}"
>
  <div class="nq-carousel-track" id="nq-track-{{ block.id }}">
    {%- comment -%} Skeleton loaders shown while JS fetches videos {%- endcomment -%}
    {% for i in (1..5) %}
      <div class="nq-skeleton"></div>
    {% endfor %}
  </div>
</div>

{%- comment -%} Fullscreen modal — injected once, shared across all carousels on page {%- endcomment -%}
<div class="nq-modal" id="nq-modal" role="dialog" aria-modal="true" aria-label="Video player" style="display:none;">
  <div class="nq-modal-bg" id="nq-modal-bg"></div>

  <div class="nq-modal-layout">

    {%- comment -%} Far-left navigation arrow {%- endcomment -%}
    <button class="nq-arrow-btn nq-arrow-prev" id="nq-arrow-prev" aria-label="Previous video">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>

    {%- comment -%} Single-column video with overlays {%- endcomment -%}
    <div class="nq-modal-main">
      <div class="nq-modal-video-panel">
        <button class="nq-close-btn" id="nq-close-btn" aria-label="Close video">
          <svg width="14" height="14" viewBox="0 0 18 18" fill="none">
            <path d="M1 1l16 16M17 1L1 17" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
        </button>

        <div class="nq-counter" id="nq-counter">1</div>

        {%- comment -%} Swiper — JS fills swiper-wrapper with slides {%- endcomment -%}
        <div class="swiper nq-video-swiper" id="nq-video-swiper">
          <div class="swiper-wrapper" id="nq-swiper-wrapper"></div>
        </div>

        {%- comment -%} Right-side actions: mute, like, share {%- endcomment -%}
        <div class="nq-side-actions">
          <button class="nq-side-btn nq-mute-btn" id="nq-mute-btn" aria-label="Toggle mute">
            <svg id="nq-icon-sound" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="display:none">
              <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/>
            </svg>
            <svg id="nq-icon-muted" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
            </svg>
          </button>

          <div class="nq-side-item">
            <button class="nq-side-btn nq-like-btn" id="nq-like-btn" aria-label="Like">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </button>
            <span class="nq-side-label">Like</span>
          </div>

          <div class="nq-side-item">
            <button class="nq-side-btn nq-share-btn" id="nq-share-btn" aria-label="Share">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
              </svg>
            </button>
            <span class="nq-side-label">Share</span>
          </div>
        </div>

        {%- comment -%} Product card overlaid at the bottom {%- endcomment -%}
        <div class="nq-product-overlay" id="nq-product-card"></div>
      </div>
    </div>

    {%- comment -%} Far-right navigation arrow {%- endcomment -%}
    <button class="nq-arrow-btn nq-arrow-next" id="nq-arrow-next" aria-label="Next video">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>

  </div>
</div>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
{{ 'shoppable-video.css' | asset_url | stylesheet_tag }}
<script src="{{ 'shoppable-video.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Shoppable Videos",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Shop Our Looks"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Button Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Shop Now"
    }
  ],
}
{% endschema %}
