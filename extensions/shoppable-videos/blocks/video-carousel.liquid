{%- comment -%} Device visibility (CSS fallback; JS also handles it) + mobile heading size {%- endcomment -%}
{%- assign sd = block.settings.show_on_device -%}
<style>
  {%- if sd == 'desktop_only' -%}
  @media (max-width: 767px) { #nq-sec-{{ block.id }} { display: none !important; } }
  {%- elsif sd == 'mobile_only' -%}
  @media (min-width: 768px) { #nq-sec-{{ block.id }} { display: none !important; } }
  {%- endif -%}
  @media (max-width: 767px) {
    #nq-sec-{{ block.id }} .nq-heading { font-size: {{ block.settings.heading_size_mobile }}px !important; }
  }
</style>

{%- comment -%} On a product page the whole section is shown on mobile only (nq-pdp-mobile-only). {%- endcomment -%}
<div id="nq-sec-{{ block.id }}" class="nq-section{% if product %} nq-pdp-mobile-only{% endif %}"
     style="padding: {{ block.settings.vertical_padding }}px {{ block.settings.horizontal_padding }}px;">

  {%- if block.settings.heading != blank -%}
    <h2 class="nq-heading"
        style="font-size: {{ block.settings.heading_size_desktop }}px; color: {{ block.settings.heading_color }}; text-align: {{ block.settings.heading_align }}; margin: 0 0 4px;">
      {{ block.settings.heading }}
    </h2>
  {%- endif -%}

  {%- if block.settings.subheading != blank -%}
    <p class="nq-subheading"
       style="color: {{ block.settings.subheading_color }}; text-align: {{ block.settings.heading_align }}; margin: 0 0 14px; font-size: 15px; opacity: 0.75; line-height: 1.5;">
      {{ block.settings.subheading }}
    </p>
  {%- endif -%}

  <div
    class="nq-shoppable-carousel"
    id="nq-carousel-{{ block.id }}"
    data-shop="{{ shop.permanent_domain }}"
    data-block-id="{{ block.id }}"
    data-product-id="{{ product.id }}"
    data-product-handle="{{ product.handle }}"
    data-tile-type="{{ block.settings.tile_type }}"
    data-card-width="{{ block.settings.card_width }}"
    data-card-height="{{ block.settings.card_height }}"
    data-shop-btn-color="{{ block.settings.shop_btn_color }}"
    data-autoplay="{{ block.settings.autoplay }}"
    data-show-views="{{ block.settings.show_views }}"
  >
    <div class="nq-carousel-track" id="nq-track-{{ block.id }}">
      {%- comment -%} Skeleton loaders shown while JS fetches videos {%- endcomment -%}
      {% for i in (1..5) %}
        <div class="nq-skeleton"></div>
      {% endfor %}
    </div>
  </div>

  {%- if block.settings.feature_caption != blank -%}
    <p class="nq-feature-caption">
      {{ block.settings.feature_caption }}{% if block.settings.instagram_handle != blank %} <a class="nq-feature-link" href="{{ block.settings.instagram_url }}" target="_blank" rel="noopener nofollow">{{ block.settings.instagram_handle }}</a>{% endif %} {{ block.settings.feature_caption_suffix }}
    </p>
  {%- endif -%}
</div>

{%- comment -%} Fullscreen modal — V2 working player, shared across carousels {%- endcomment -%}
<div class="nq-modal" id="nq-modal" role="dialog" aria-modal="true" aria-label="Video player" style="display:none;">
  <div class="nq-modal-bg" id="nq-modal-bg"></div>

  <div class="nq-modal-layout">

    <button class="nq-arrow-btn nq-arrow-prev" id="nq-arrow-prev" aria-label="Previous video">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>

    <div class="nq-modal-main">
      <div class="nq-modal-video-panel">
        <button class="nq-close-btn" id="nq-close-btn" aria-label="Close video">
          <svg width="14" height="14" viewBox="0 0 18 18" fill="none">
            <path d="M1 1l16 16M17 1L1 17" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
        </button>

        <div class="nq-counter" id="nq-counter">1</div>

        <div class="swiper nq-video-swiper" id="nq-video-swiper">
          <div class="swiper-wrapper" id="nq-swiper-wrapper"></div>
        </div>

        {%- comment -%} Mobile-only hint: tells users to swipe up for the next video {%- endcomment -%}
        <div class="nq-swipe-hint" id="nq-swipe-hint" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="18 15 12 9 6 15"/>
          </svg>
          <span>Swipe up for next</span>
        </div>

        <div class="nq-side-actions">
          <button class="nq-side-btn nq-mute-btn" id="nq-mute-btn" aria-label="Toggle mute">
            <svg id="nq-icon-sound" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="display:none">
              <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/>
            </svg>
            <svg id="nq-icon-muted" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
            </svg>
          </button>

          <div class="nq-side-item">
            <button class="nq-side-btn nq-like-btn" id="nq-like-btn" aria-label="Like">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </button>
            <span class="nq-side-label">Like</span>
          </div>

          <div class="nq-side-item">
            <button class="nq-side-btn nq-share-btn" id="nq-share-btn" aria-label="Share">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
              </svg>
            </button>
            <span class="nq-side-label">Share</span>
          </div>
        </div>

        <div class="nq-product-overlay" id="nq-product-card"></div>
      </div>
    </div>

    <button class="nq-arrow-btn nq-arrow-next" id="nq-arrow-next" aria-label="Next video">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>

  </div>
</div>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
{%- comment -%} Modal styles first, then layout styles (layout wins on the few shared classes) {%- endcomment -%}
{{ 'shoppable-video.css' | asset_url | stylesheet_tag }}
{{ 'nq-carousel.css' | asset_url | stylesheet_tag }}
<script src="{{ 'shoppable-video.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Shoppable Videos",
  "target": "section",
  "settings": [
    { "type": "text",  "id": "heading",             "label": "Heading",                          "default": "Watch And Buy" },
    { "type": "textarea", "id": "subheading", "label": "Paragraph / Subheading" },
    { "type": "range", "id": "heading_size_desktop", "label": "Heading Font Size - Desktop (px)", "min": 20, "max": 80,  "step": 2, "default": 40 },
    { "type": "range", "id": "heading_size_mobile",  "label": "Heading Font Size - Mobile (px)",  "min": 16, "max": 60,  "step": 2, "default": 28 },
    { "type": "range", "id": "horizontal_padding",   "label": "Horizontal Padding (px)",          "min": 0,  "max": 100, "step": 4, "default": 40 },
    { "type": "range", "id": "vertical_padding",     "label": "Vertical Padding (px)",            "min": 0,  "max": 100, "step": 4, "default": 20 },
    { "type": "range", "id": "card_height",          "label": "Video Card Height (px)",           "min": 200, "max": 600, "step": 20, "default": 340 },
    { "type": "range", "id": "card_width",           "label": "Video Card Width (px)",            "min": 120, "max": 400, "step": 10, "default": 200 },
    {
      "type": "select",
      "id": "show_on_device",
      "label": "Show On Device",
      "info": "Control which devices this video section is visible on",
      "options": [
        { "value": "all",          "label": "All Devices"    },
        { "value": "desktop_only", "label": "Desktop Only"   },
        { "value": "mobile_only",  "label": "Mobile Only"    }
      ],
      "default": "all"
    },
    {
      "type": "select", "id": "tile_type", "label": "Tile Type",
      "info": "'2 tiles' and '3 tiles' refer to the layout in mobile view",
      "options": [
        { "value": "hero_slide",                     "label": "Video Card-Hero Featured + Side Slide" },
        { "value": "img_transparent_text_overlay_3", "label": "Video Card-Img & Transparent Text Overlay-3 tiles" },
        { "value": "img_transparent_text_overlay_2", "label": "Video Card-Img & Transparent Text Overlay-2 tiles" },
        { "value": "img_opaque_text_overlay_3",      "label": "Video Card-Img & Opaque Text Overlay-3 tiles" },
        { "value": "single_tile_no_overlay",         "label": "Video Card-Single Tile (No Overlay)" },
        { "value": "product_below_3",                "label": "Video Card-Product Info Below tile-3 tiles" },
        { "value": "product_below_2",                "label": "Video Card-Product Info Below tile-2 tiles" },
        { "value": "story_format",                   "label": "Video Card-Story Like Format" },
        { "value": "feed_view_more",                 "label": "Video Card Feed-View More" },
        { "value": "feed_on_scroll",                 "label": "Video Card Feed-On Scroll" },
        { "value": "grid_theme_border",              "label": "Video Card Grid-Theme Border" },
        { "value": "grid_no_border",                 "label": "Video Card Grid-No Border" },
        { "value": "3d_navigation",                  "label": "Video Card 3D Navigation" },
        { "value": "minimal",                        "label": "Video Card Minimal" }
      ],
      "default": "product_below_3"
    },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#000000" },
    { "type": "color", "id": "subheading_color", "label": "Subheading Color", "default": "#000000" },
    {
      "type": "select", "id": "heading_align", "label": "Heading Alignment",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right"  }
      ],
      "default": "left"
    },
    { "type": "color",    "id": "shop_btn_color", "label": "Shop Now Button Color", "default": "#000000" },
    { "type": "checkbox", "id": "autoplay",       "label": "Autoplay on hover",     "default": true },
    { "type": "checkbox", "id": "show_views",     "label": "Show view count",       "default": true },
    { "type": "header", "content": "Featured Caption (mobile)" },
    { "type": "text", "id": "feature_caption", "label": "Caption text", "default": "Want to be featured here? Send us your Claura video or tag" },
    { "type": "text", "id": "instagram_handle", "label": "Instagram handle (clickable)", "default": "@claura.in" },
    { "type": "text", "id": "instagram_url", "label": "Instagram URL", "default": "https://www.instagram.com/claura.in" },
    { "type": "text", "id": "feature_caption_suffix", "label": "Caption text after handle", "default": "on Instagram" }
  ]
}
{% endschema %}
